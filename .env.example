# ─────────────────────────────────────────────────────────────
# HELIX Configuration — copy to .env and fill in values
# NEVER commit the actual .env file to git
# ─────────────────────────────────────────────────────────────

# Helios API authentication
# Obtain from: Helios UI → Settings → Access Management → API Keys → Add API Key
HELIOS_API_KEY=your-api-key-here

# Helios base URL (default is SaaS; override for on-prem Helios)
HELIOS_BASE_URL=https://helios.cohesity.com/irisservices/api/v1/public

# Target cluster details
CLUSTER_IP=10.0.0.100
CLUSTER_ID=1234567890
CLUSTER_NAME=lab-cluster-01

# SSH access to cluster nodes (for tool runners and fault injection)
SSH_USERNAME=cohesity
SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_PASSWORD=           # Alternative to key auth (not recommended)

# Test environment (controls which markers are allowed)
# Options: lab | staging | prod-ro
TEST_ENV=lab

# S3 endpoint (Cohesity S3-compatible API)
S3_ENDPOINT=http://10.0.0.100:80
S3_ACCESS_KEY=cohesity-access-key
S3_SECRET_KEY=cohesity-secret-key
S3_REGION=us-east-1

# NFS settings
NFS_SERVER=10.0.0.100
NFS_EXPORT=/cohesity/nfs-test

# SMB settings
SMB_SERVER=10.0.0.100
SMB_SHARE=cohesity-test
SMB_USERNAME=testuser
SMB_PASSWORD=testpass
SMB_DOMAIN=COHESITY

# iSCSI settings
ISCSI_PORTAL=10.0.0.100:3260
ISCSI_TARGET_IQN=iqn.2020-01.com.cohesity:test

# Performance baselines
BASELINE_STORE_TYPE=json        # json | sqlite
BASELINE_DB_PATH=baselines/helix_baselines.db
PERF_REGRESSION_THRESHOLD=0.05  # 5%

# tshark capture interface (override per environment)
CAPTURE_INTERFACE=eth0
